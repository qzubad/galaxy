<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Galaxxy</title>
<style>
html,body,canvas{margin:0;width:100%;height:100%;display:block;background:#000;overflow:hidden}
</style>
</head>
<body>
<canvas id="c"></canvas>
<script>
const canvas=document.getElementById("c");
const gl=canvas.getContext("webgl2",{antialias:false,alpha:false,powerPreference:"high-performance"});
if(!gl) throw new Error("WebGL2 required");

function resize(){
 canvas.width=innerWidth;
 canvas.height=innerHeight;
 gl.viewport(0,0,canvas.width,canvas.height);
}
addEventListener('resize',resize);
resize();

const vs=`#version 300 es
precision highp float;
layout(location=0) in vec3 p;
layout(location=1) in vec3 col;
uniform float time;
out vec3 vCol;
void main(){
 vec3 q=p;
 float a=time*0.08 + length(q.xy)*0.2;
 mat2 r=mat2(cos(a),-sin(a),sin(a),cos(a));
 q.xy=r*q.xy;
 q.x+=sin(time+q.z*3.0)*0.03;
 q.y+=cos(time+q.x*2.0)*0.03;
 float z=q.z+10.0;
 gl_Position=vec4(q.xy/z,0.0,1.0);
 gl_PointSize=max(1.0,5.0/z);
 vCol=col;
}`;

const fs=`#version 300 es
precision highp float;
in vec3 vCol;
out vec4 outColor;
void main(){
 vec2 uv=gl_PointCoord*2.0-1.0;
 float d=dot(uv,uv);
 if(d>1.0) discard;
 float g=exp(-d*6.0);
 outColor=vec4(vCol*g*4.0,g);
}`;

function sh(t,s){const x=gl.createShader(t);gl.shaderSource(x,s);gl.compileShader(x);return x;}
const p=gl.createProgram();
gl.attachShader(p,sh(gl.VERTEX_SHADER,vs));
gl.attachShader(p,sh(gl.FRAGMENT_SHADER,fs));
gl.linkProgram(p);
gl.useProgram(p);

const COUNT=3000000;

const pos=new Float32Array(COUNT*3);
const col=new Float32Array(COUNT*3);

for(let i=0;i<COUNT;i++){
 const arm=i&7;
 const rr=Math.pow(Math.random(),0.55)*6.0;
 const ang=(i*0.00008)+arm*0.785398;
 pos[i*3]=Math.cos(ang)*rr+(Math.random()-0.5)*0.15;
 pos[i*3+1]=Math.sin(ang)*rr+(Math.random()-0.5)*0.15;
 pos[i*3+2]=(Math.random()-0.5)*8.0;

 col[i*3]=0.5+Math.random()*0.5;
 col[i*3+1]=0.2+Math.random()*0.8;
 col[i*3+2]=0.5+Math.random()*0.5;
}

const vao=gl.createVertexArray();
gl.bindVertexArray(vao);

let b=gl.createBuffer();
gl.bindBuffer(gl.ARRAY_BUFFER,b);
gl.bufferData(gl.ARRAY_BUFFER,pos,gl.STATIC_DRAW);
gl.vertexAttribPointer(0,3,gl.FLOAT,false,0,0);
gl.enableVertexAttribArray(0);

b=gl.createBuffer();
gl.bindBuffer(gl.ARRAY_BUFFER,b);
gl.bufferData(gl.ARRAY_BUFFER,col,gl.STATIC_DRAW);
gl.vertexAttribPointer(1,3,gl.FLOAT,false,0,0);
gl.enableVertexAttribArray(1);

gl.enable(gl.BLEND);
gl.blendFunc(gl.SRC_ALPHA,gl.ONE);

const u=gl.getUniformLocation(p,"time");

function loop(ms){
 gl.clearColor(0,0,0,1);
 gl.clear(gl.COLOR_BUFFER_BIT);
 gl.uniform1f(u,ms*0.001);
 gl.drawArrays(gl.POINTS,0,COUNT);
 requestAnimationFrame(loop);
}
requestAnimationFrame(loop);
</script>
</body>
</html>
